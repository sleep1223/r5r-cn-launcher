{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "R5R-CN-Launcher",
  "version": "0.5.0",
  "identifier": "com.r5r-cn.launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "R5R 中国镜像启动器",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGMTQ0MDQ0RDUxNDE1QTUKUldTbEZSVFZSRUFVUHhtbDhUMjJ5QTdWRlFMcXRVOFd1SnNWbi9NUkt5UzUrcjdkNDBtbmpYWGgK",
      "endpoints": [
        "https://r5.sleep0.de/api/v1/r5/launcher/update/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
